{
  "name": "neo-qc",
  "version": "1.4.0",
  "description": "PC Assembly Workflow & Quality Control Tracker for Neo Tokyo Kochi",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "node build-helper.js selector && electron-builder --config electron-builder.json",
    "sync-shared": "node sync-shared.js"
  },
  "keywords": [
    "pc",
    "qc",
    "assembly",
    "electron"
  ],
  "author": "Ananthakrishnan / Neo Tokyo Kochi",
  "license": "ISC",
  "devDependencies": {
    "bluebird": "^3.7.2",
    "electron": "^42.4.0",
    "electron-builder": "^24.13.3",
    "extract-zip": "^2.0.1"
  },
  "build": {
    "appId": "com.neotokyo.neoqc",
    "productName": "NeoQC",
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true
    },
    "publish": {
      "provider": "github",
      "owner": "akruunnithan21-ship-it",
      "repo": "neoqc"
    },
    "asarUnpack": [
      "assets/diagnostics/**"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "fuse.js": "^7.4.2"
  }
}
