{
  "name": "neo-qc",
  "version": "1.0.0",
  "description": "PC Assembly Workflow & Quality Control Tracker for Neo Tokyo Kochi",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:client": "node build-helper.js client && electron-builder --config electron-builder-client.json",
    "build:admin": "node build-helper.js admin && electron-builder --config electron-builder-admin.json",
    "build": "npm run build:client && npm run build:admin"
  },
  "keywords": [
    "pc",
    "qc",
    "assembly",
    "electron"
  ],
  "author": "Ananthakrishnan / Neo Tokyo Kochi",
  "license": "ISC",
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.neotokyo.neoqc",
    "productName": "NeoQC",
    "win": {
      "target": "portable",
      "icon": "assets/icon.ico"
    },
    "directories": {
      "output": "dist"
    }
  }
}
