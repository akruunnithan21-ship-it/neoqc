{
  "appId": "com.neotokyo.neoqc.admin",
  "productName": "NeoQC Admin",
  "win": {
    "target": [
      "nsis",
      "portable"
    ],
    "icon": "assets/icon.ico",
    "requestedExecutionLevel": "requireAdministrator"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": true
  },
  "publish": {
    "provider": "github",
    "owner": "akruunnithan21-ship-it",
    "repo": "neoqc"
  },
  "asarUnpack": [
    "assets/diagnostics/**"
  ],
  "directories": {
    "output": "dist"
  }
}
